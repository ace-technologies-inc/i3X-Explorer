server {
    listen 8090;
    server_name your-hostname-or-ip;

    root /path/to/i3X-Explorer/dist-web;
    index index.html;

    # SPA fallback — all routes served by index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy to your I3X API server.
    # Users enter http://<host>:8090/api as the server URL in the connection dialog.
    # Replace http://127.0.0.1:8080 with the actual I3X server address/port.
    location /api/ {
        proxy_pass http://127.0.0.1:8080/;

        add_header 'Access-Control-Allow-Origin' '$http_origin' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization' always;

        if ($request_method = 'OPTIONS') {
            return 204;
        }

        # SSE / long-poll support
        proxy_buffering          off;
        proxy_cache              off;
        proxy_read_timeout       86400s;
        proxy_http_version       1.1;
        proxy_set_header         Connection '';
        proxy_set_header         Host $host;
        proxy_set_header         X-Real-IP $remote_addr;
        proxy_set_header         X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header         X-Forwarded-Proto $scheme;
    }
}
